# --- Required ---------------------------------------------------------------
# Wireless interface to turn into an access point (must support AP mode).
WIFI_INTERFACE=wlan0
# WPA2 passphrase for the hotspot (min 8 characters).
WIFI_PASSWORD=changeme123

# --- Proxy ------------------------------------------------------------------
# Proxy running on the host. Format: proto://[user:pass@]host:port
# proto is one of: socks5, socks4, http. With network_mode: host, 127.0.0.1
# is the host itself.
PROXY=socks5://127.0.0.1:1080

# --- WiFi -------------------------------------------------------------------
SSID=Hotspot
WIFI_CHANNEL=6
WIFI_HW_MODE=g          # g = 2.4GHz, a = 5GHz
COUNTRY_CODE=US

# --- LAN / DHCP -------------------------------------------------------------
HOTSPOT_ADDR=192.168.50.1
HOTSPOT_PREFIX=24
HOTSPOT_SUBNET=192.168.50.0/24
DHCP_START=192.168.50.10
DHCP_END=192.168.50.200
DHCP_NETMASK=255.255.255.0
DHCP_LEASE=12h

# --- Tunnel -----------------------------------------------------------------
TUN_NAME=tun0
TUN_MTU=1500
# DNS handling: virtual (recommended, tunnels DNS over the proxy as TCP),
# over-tcp, or direct.
DNS_STRATEGY=virtual
# DNS server handed to clients. With DNS_STRATEGY=virtual this is tun2proxy's
# virtual resolver; queries to it are intercepted inside the tunnel.
CLIENT_DNS=198.18.0.1
RT_TABLE=100
LOG_LEVEL=info          # off, error, warn, info, debug, trace
